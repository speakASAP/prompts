# Copy to .env (never commit .env). See shared/docs/ENV_FILE_STANDARD.md and shared/docs/DEPLOY_STANDARD.md

# =============================================================================
# Identity
# =============================================================================
NODE_ENV=production
DOMAIN=prompts.alfares.cz
SERVICE_NAME=prompts-microservice

# =============================================================================
# Ports
# =============================================================================
PORT=4750
PORT_GREEN=4751
CONTAINER_PORT=3000

# =============================================================================
# Network
# =============================================================================
NGINX_NETWORK_NAME=nginx-network

# =============================================================================
# Shared microservices
# =============================================================================
AUTH_SERVICE_URL=http://auth-microservice:3370
LOGGING_SERVICE_URL=http://logging-microservice:3367
LOGGING_SERVICE_API_PATH=/api/logs
LOGGING_ENABLED=true

# =============================================================================
# Database
# =============================================================================
DB_HOST=db-server-postgres
DB_PORT=5432
DB_USER=dbadmin
DB_PASSWORD=
DB_NAME=prompts_microservice

# =============================================================================
# Auth/session
# =============================================================================
AUTH_COOKIE_NAME=prompts_auth_token
